---
import Layout from '../layouts/Layout.astro';
import Dashboard from '../components/Dashboard.tsx';
import ThemeToggle from '../components/ThemeToggle.tsx';
import programas from '../data/doctorados-educacion.json';
---

<Layout
  title="Doctorados en Educación en Chile — Programas de Posgrado Nacional"
  description="Dashboard comparativo de todos los Doctorados en Educación de Chile: arancel, modalidad, duración y acreditación."
>
  <header class="border-b border-[var(--border-color)] bg-[var(--surface)]">
    <div class="max-w-[1800px] mx-auto px-6 sm:px-10 py-10 flex items-start justify-between gap-6">
      <div>
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wide mb-2">Programas de Posgrado Nacional</p>
        <h1 class="text-3xl sm:text-5xl font-bold text-[var(--text-primary)]">Doctorados en Educación en Chile</h1>
        <p class="text-[var(--text-secondary)] text-lg mt-3 max-w-3xl">
          Compara arancel, duración, modalidad y tipo de institución de los programas de Doctorado en Educación
          vigentes en Chile. Filtra por presupuesto y modalidad, y accede al sitio oficial de cada programa.
        </p>
      </div>
      <ThemeToggle client:load />
    </div>
  </header>

  <main class="max-w-[1800px] mx-auto px-6 sm:px-10 py-10">
    <Dashboard programas={programas} client:load />
  </main>

  <footer class="max-w-[1800px] mx-auto px-6 sm:px-10 py-10 text-sm text-[var(--text-muted)] border-t border-[var(--border-color)] mt-8">
    Datos recopilados desde las webs oficiales de cada universidad y fuentes públicas (CNA, ANID). Verifica el
    arancel y las vacantes directamente en el sitio del programa antes de postular.
  </footer>
</Layout>
