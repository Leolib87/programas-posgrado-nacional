---
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const path = Astro.url.pathname;

const links = [
  { href: base, label: 'Chile', match: (p: string) => p === base },
  { href: `${base}internacional/`, label: 'Internacional', match: (p: string) => p.startsWith(`${base}internacional`) },
];
---

<nav class="border-b border-[var(--border-color)] bg-[var(--surface)]">
  <div class="max-w-[1800px] mx-auto px-6 sm:px-10 flex items-center gap-1">
    {links.map((link) => {
      const active = link.match(path);
      return (
        <a
          href={link.href}
          class:list={[
            'px-4 py-3.5 text-base font-medium border-b-2 transition',
            active
              ? 'border-brand-500 text-brand-600'
              : 'border-transparent text-[var(--text-muted)] hover:text-[var(--text-primary)]',
          ]}
        >
          {link.label}
        </a>
      );
    })}
  </div>
</nav>
